<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_amoled"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/settingsToolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_amoled"
        app:titleTextColor="@color/on_surface"
        app:title="Operation Mode"
        app:popupTheme="@style/ThemeOverlay.MaterialComponents.Dark" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Escolha como o escalonamento de resolução é aplicado."
                android:textSize="14sp"
                android:textColor="@color/on_surface_variant"
                android:paddingBottom="16dp" />

            <!-- RadioGroup invisível — necessário para o Kotlin existente funcionar -->
            <RadioGroup
                android:id="@+id/radioGroupMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CARD Modo Padrão -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardDefault"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/primary_container"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/primary"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <RadioButton
                            android:id="@+id/radioDefault"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"
                            android:buttonTint="@color/primary"
                            android:layout_marginTop="2dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Default Mode"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_primary_container"
                                android:paddingBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• Usa comandos cmd game downscale\n• Recomendado para a maioria dos usuários\n• Funciona a partir do Android 14+\n• Mais estável e bem testado\n• Reaplicado automaticamente ao abrir o app"
                                android:textSize="13sp"
                                android:textColor="@color/on_primary_container"
                                android:lineSpacingMultiplier="1.4" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- CARD Modo Alternativo -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardAlternative"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/surface_2"
                    app:cardCornerRadius="24dp"
                    app:strokeColor="@color/outline"
                    app:strokeWidth="1.5dp"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="16dp">
                        <RadioButton
                            android:id="@+id/radioAlternative"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:buttonTint="@color/primary"
                            android:layout_marginTop="2dp" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:paddingStart="8dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Alternative Mode"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/on_surface"
                                android:paddingBottom="8dp" />
                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="• Usa comandos device_config game_overlay\n• Desabilita sincronização GMS\n• Suporte experimental para Android 13+\n• Pode não funcionar em todas as ROMs\n• Reaplicado automaticamente ao abrir o app"
                                android:textSize="13sp"
                                android:textColor="@color/on_surface_variant"
                                android:lineSpacingMultiplier="1.4" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </RadioGroup>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
