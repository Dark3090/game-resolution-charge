<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/itemCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="2dp"
    app:cardBackgroundColor="@color/bg_amoled"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical">
        <FrameLayout
            android:layout_width="52dp"
            android:layout_height="52dp">
            <com.google.android.material.card.MaterialCardView
                android:layout_width="52dp"
                android:layout_height="52dp"
                app:cardBackgroundColor="@color/surface_3"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp">
                <ImageView
                    android:id="@+id/appIcon"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:padding="6dp"
                    android:scaleType="centerInside" />
            </com.google.android.material.card.MaterialCardView>
            <View
                android:id="@+id/modDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="1dp"
                android:background="@drawable/ic_mod_dot"
                android:visibility="gone" />
        </FrameLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">
            <TextView
                android:id="@+id/appName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/on_surface"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/packageName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="@color/on_surface_variant"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp" />
        </LinearLayout>
        <com.google.android.material.chip.Chip
            android:id="@+id/scaleBadge"
            style="@style/Widget.MaterialComponents.Chip.Entry"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="80%"
            android:textColor="@color/on_primary_container"
            android:textSize="12sp"
            app:chipBackgroundColor="@color/primary_container"
            app:chipStrokeColor="@color/primary_dim"
            app:chipStrokeWidth="1dp"
            app:chipMinHeight="28dp"
            android:visibility="gone" />
        <!-- mantido por compatibilidade com AppListAdapter -->
        <ImageView
            android:id="@+id/modifiedIcon"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:visibility="gone" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
